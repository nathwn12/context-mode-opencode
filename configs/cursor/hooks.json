{
  "version": 1,
  "hooks": {
    "preToolUse": [
      {
        "command": "context-mode-opencode hook cursor pretooluse",
        "matcher": "Shell|Read|Grep|WebFetch|mcp_web_fetch|mcp_fetch_tool|Task|MCP:ctx_execute|MCP:ctx_execute_file|MCP:ctx_batch_execute"
      }
    ],
    "postToolUse": [
      {
        "command": "context-mode-opencode hook cursor posttooluse"
      }
    ],
    "stop": [
      {
        "command": "context-mode-opencode hook cursor stop"
      }
    ]
  }
}
