{
  "name": "context-mode-opencode",
  "description": "Context-mode-opencode hooks for context window protection",
  "hooks": {
    "preToolUse": [
      {
        "matcher": "*",
        "command": "context-mode-opencode hook kiro pretooluse"
      }
    ],
    "postToolUse": [
      {
        "matcher": "*",
        "command": "context-mode-opencode hook kiro posttooluse"
      }
    ]
  }
}
